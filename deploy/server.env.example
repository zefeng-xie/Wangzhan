# Copy this file to deploy/server.env and fill in your real server values.
SERVER_HOST=
SERVER_PORT=22
SERVER_USER=root
SSH_KEY_PATH=

# Optional domains. If blank, the generated Nginx config falls back to SERVER_HOST.
SERVER_DOMAIN=
SERVER_ALT_DOMAIN=

SERVER_BASE_DIR=/var/www/wangzhan
SERVER_REPO_DIR=/var/www/wangzhan/repo
SERVER_FRONTEND_DIR=/var/www/wangzhan/frontend-dist

BACKEND_PORT=3001

# Leave blank when you deploy the frontend and backend behind the same domain.
CORS_ORIGIN=